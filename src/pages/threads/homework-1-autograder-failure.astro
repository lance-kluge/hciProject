---
import LeftSidebar from '../../components/sidebar/LeftSidebar.astro';
import TopBarHeader from '../../components/TopBarHeader.astro';
import { unreadCount } from '../../data/sidebar';
import '../../styles/global.css';
---

<html lang="en">
	<head>
		<meta charset="utf-8" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<link rel="icon" href="/favicon.ico" />
		<meta name="viewport" content="width=device-width" />
		<meta name="generator" content={Astro.generator} />
		<title>Homework 1 Autograder Failure</title>
	</head>
	<body class="min-h-screen bg-slate-100 text-slate-900">
		<main class="flex min-h-screen">
			<LeftSidebar />
			<div class="flex min-h-screen flex-1 flex-col">
				<TopBarHeader title="Messenger" unreadCount={unreadCount} />
				<section class="flex-1 p-6 lg:p-10">
					<div class="mx-auto max-w-4xl space-y-6">
						<a
							href="/"
							class="inline-flex items-center rounded-md border border-slate-300 bg-white px-3 py-2 text-sm text-slate-700 hover:bg-slate-50"
						>
							← Back to Threads
						</a>

						<article class="rounded-xl border border-slate-200 bg-white p-6 lg:p-7">
							<div class="flex flex-wrap items-center justify-between gap-3">
								<div class="flex items-center gap-2">
									<h1 class="text-2xl font-semibold">Homework 1 Autograder Failure</h1>
									<span
										id="instructor-notified-indicator"
										class="hidden rounded-md bg-rose-100 px-2.5 py-1 text-xs font-semibold text-rose-700"
									>
										Instructor Notified
									</span>
								</div>
								<span id="thread-status-badge" class="rounded-md bg-red-100 px-3 py-1.5 text-xs font-semibold text-red-700">
									4 days unanswered
								</span>
							</div>
							<div class="mt-4 flex flex-wrap items-center justify-between gap-3 rounded-lg border border-slate-200 bg-slate-50 px-4 py-3">
								<div>
									<p class="text-xs uppercase tracking-wide text-slate-500">Linked Assignment</p>
									<a
										href="#"
										class="mt-1 inline-block text-sm font-semibold text-blue-700 underline decoration-blue-300 underline-offset-2 hover:text-blue-800"
									>
										HW1
									</a>
								</div>
								<div class="rounded-md bg-amber-100 px-3 py-1.5 text-xs font-semibold text-amber-800">
									Due in 2 days
								</div>
							</div>
							<p class="mt-4 rounded-lg bg-slate-50 px-4 py-3 text-sm text-slate-700">
								AI Summary: Multiple students report failing tests despite matching expected output.
							</p>
							<div class="mt-5 space-y-4 text-sm leading-6 text-slate-700">
								<p>
									We are seeing deterministic test failures in the Homework 1 autograder for edge cases that
									pass locally. Most reports mention hidden test mismatch around whitespace handling.
								</p>
								<p>
									Students have included screenshots, local run logs, and submission timestamps. No official
									resolution has been posted yet.
								</p>
							</div>
							<div class="mt-5 grid gap-3 rounded-lg border border-slate-200 bg-slate-50 p-4 text-sm sm:grid-cols-3">
								<div>
									<p class="text-xs uppercase tracking-wide text-slate-500">I Have Same Issue</p>
									<div class="mt-1 flex items-center gap-2">
										<p id="same-issue-count" class="font-semibold">18</p>
										<button
											id="same-issue-button"
											type="button"
											class="rounded-md border border-slate-300 bg-white px-2 py-0.5 text-xs font-semibold text-slate-700 hover:bg-slate-100"
										>
											Mark
										</button>
									</div>
									<p id="same-issue-indicator" class="mt-1 hidden text-xs font-semibold text-green-700">
										You marked this issue.
									</p>
								</div>
								<div>
									<p class="text-xs uppercase tracking-wide text-slate-500">Posted</p>
									<p class="mt-1 font-semibold">4 days ago</p>
								</div>
								<div>
									<p class="text-xs uppercase tracking-wide text-slate-500">Severity</p>
									<p class="mt-1 font-semibold text-red-700">High</p>
								</div>
							</div>
							<div class="mt-5 flex items-center justify-between rounded-lg border border-slate-200 px-4 py-3">
								<div>
									<p class="text-sm font-semibold text-slate-900">Mark Thread Resolved</p>
									<p class="text-xs text-slate-600">Toggle this when the autograder issue has a confirmed fix.</p>
								</div>
								<label class="inline-flex cursor-pointer items-center gap-2">
									<input id="resolved-toggle" type="checkbox" class="h-4 w-4" />
									<span class="text-sm font-medium text-slate-700">Resolved</span>
								</label>
							</div>
						</article>

						<section class="rounded-xl border border-slate-200 bg-white p-6 lg:p-7">
							<h2 class="text-lg font-semibold">Recent Responses</h2>
							<ul class="mt-4 space-y-3 text-sm text-slate-700">
								<li class="rounded-lg border border-slate-200 bg-slate-50 p-4">
									<strong class="font-semibold">Alex M.</strong>: "My local output is identical but grader
									still marks tests 5 and 7 as failed."
								</li>
								<li class="rounded-lg border border-slate-200 bg-slate-50 p-4">
									<strong class="font-semibold">Priya R.</strong>: "I retried with fresh upload and still got
									the same hidden test mismatch."
								</li>
							</ul>
							<div class="mt-5 rounded-lg border border-slate-200 bg-slate-50 p-4">
								<label for="new-response" class="text-sm font-semibold text-slate-900">Add a Response</label>
								<textarea
									id="new-response"
									rows="3"
									placeholder="Share your attempt details, logs, or workaround..."
									class="mt-2 w-full rounded-md border border-slate-300 bg-white px-3 py-2 text-sm text-slate-800 outline-none transition focus:border-blue-500 focus:ring-2 focus:ring-blue-200"
								></textarea>
								<div class="mt-3 flex items-center justify-between gap-3">
									<p class="text-xs text-slate-500">This is a demo composer. Post will not persist.</p>
									<button
										id="post-response-button"
										type="button"
										class="rounded-md bg-blue-600 px-4 py-2 text-sm font-semibold text-white transition hover:bg-blue-700"
									>
										Post Response
									</button>
								</div>
								<p id="post-response-status" class="mt-3 hidden rounded-md bg-blue-50 px-3 py-2 text-sm font-semibold text-blue-700">
									Response posted for demo preview.
								</p>
							</div>
						</section>

						<section class="rounded-xl border border-slate-200 bg-white p-6 lg:p-7">
							<div class="flex flex-wrap items-center justify-between gap-4">
								<div>
									<h2 class="text-lg font-semibold">Need Instructor Attention?</h2>
									<p class="mt-1.5 text-sm text-slate-600">
										Use this action to notify the instructor about unresolved grading issues.
									</p>
								</div>
								<button
									id="notify-instructor-button"
									type="button"
									class="rounded-md bg-red-600 px-5 py-2.5 text-sm font-semibold text-white transition hover:bg-red-700"
								>
									Notify Instructor
								</button>
							</div>
							<p id="notify-status" class="mt-4 hidden rounded-md bg-green-50 px-3 py-2 text-sm font-semibold text-green-700">
								Instructor has been notified.
							</p>
						</section>
					</div>
				</section>
			</div>
		</main>
		<script is:inline>
			const notifyButton = document.getElementById('notify-instructor-button');
			const notifyStatus = document.getElementById('notify-status');
			const resolvedToggle = document.getElementById('resolved-toggle');
			const threadStatusBadge = document.getElementById('thread-status-badge');
			const postResponseButton = document.getElementById('post-response-button');
			const postResponseStatus = document.getElementById('post-response-status');
			const sameIssueButton = document.getElementById('same-issue-button');
			const sameIssueCount = document.getElementById('same-issue-count');
			const sameIssueIndicator = document.getElementById('same-issue-indicator');
			const instructorNotifiedIndicator = document.getElementById('instructor-notified-indicator');

			const STORAGE_KEY_SAME_ISSUE = 'thread-homework-1-same-issue-voted';
			const STORAGE_KEY_INSTRUCTOR_NOTIFIED = 'thread-homework-1-instructor-notified';

			const setSameIssueVotedState = () => {
				if (!sameIssueButton || !sameIssueIndicator) {
					return;
				}
				sameIssueButton.textContent = 'Uncheck';
				sameIssueButton.classList.remove('border-slate-300', 'bg-white', 'text-slate-700');
				sameIssueButton.classList.add('border-green-300', 'bg-green-100', 'text-green-800');
				sameIssueIndicator.classList.remove('hidden');
			};

			const setSameIssueUnvotedState = () => {
				if (!sameIssueButton || !sameIssueIndicator) {
					return;
				}
				sameIssueButton.textContent = 'Mark';
				sameIssueButton.classList.remove('border-green-300', 'bg-green-100', 'text-green-800');
				sameIssueButton.classList.add('border-slate-300', 'bg-white', 'text-slate-700');
				sameIssueIndicator.classList.add('hidden');
			};

			const setInstructorNotifiedState = () => {
				if (!notifyButton || !notifyStatus || !instructorNotifiedIndicator) {
					return;
				}
				notifyButton.setAttribute('disabled', 'true');
				notifyButton.classList.add('cursor-not-allowed', 'opacity-70');
				notifyButton.textContent = 'Instructor Notified';
				notifyStatus.classList.remove('hidden');
				instructorNotifiedIndicator.classList.remove('hidden');
			};

			if (localStorage.getItem(STORAGE_KEY_SAME_ISSUE) === 'true') {
				setSameIssueVotedState();
			} else {
				setSameIssueUnvotedState();
			}

			if (localStorage.getItem(STORAGE_KEY_INSTRUCTOR_NOTIFIED) === 'true') {
				setInstructorNotifiedState();
			}

			if (notifyButton && notifyStatus) {
				notifyButton.addEventListener('click', () => {
					setInstructorNotifiedState();
					localStorage.setItem(STORAGE_KEY_INSTRUCTOR_NOTIFIED, 'true');
				});
			}

			if (resolvedToggle && threadStatusBadge) {
				resolvedToggle.addEventListener('change', () => {
					if (resolvedToggle.checked) {
						threadStatusBadge.textContent = 'Resolved';
						threadStatusBadge.classList.remove('bg-red-100', 'text-red-700');
						threadStatusBadge.classList.add('bg-green-100', 'text-green-700');
					} else {
						threadStatusBadge.textContent = '4 days unanswered';
						threadStatusBadge.classList.remove('bg-green-100', 'text-green-700');
						threadStatusBadge.classList.add('bg-red-100', 'text-red-700');
					}
				});
			}

			if (postResponseButton && postResponseStatus) {
				postResponseButton.addEventListener('click', () => {
					postResponseStatus.classList.remove('hidden');
				});
			}

			if (sameIssueButton && sameIssueCount) {
				sameIssueButton.addEventListener('click', () => {
					const isVoted = localStorage.getItem(STORAGE_KEY_SAME_ISSUE) === 'true';

					if (isVoted) {
						const nextCount = Math.max(0, Number(sameIssueCount.textContent || '0') - 1);
						sameIssueCount.textContent = String(nextCount);
						localStorage.setItem(STORAGE_KEY_SAME_ISSUE, 'false');
						setSameIssueUnvotedState();
						return;
					}

					const nextCount = Number(sameIssueCount.textContent || '0') + 1;
					sameIssueCount.textContent = String(nextCount);
					localStorage.setItem(STORAGE_KEY_SAME_ISSUE, 'true');
					setSameIssueVotedState();
				});
			}
		</script>
	</body>
</html>
