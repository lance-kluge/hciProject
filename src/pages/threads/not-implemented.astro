---
import LeftSidebar from '../../components/sidebar/LeftSidebar.astro';
import TopBarHeader from '../../components/TopBarHeader.astro';
import { unreadCount } from '../../data/sidebar';
import '../../styles/global.css';

const threadTitle = Astro.url.searchParams.get('thread') ?? 'Unknown Thread';
const withBase = (path: string) => `${import.meta.env.BASE_URL}${path.replace(/^\//, '')}`;
---

<html lang="en">
	<head>
		<meta charset="utf-8" />
		<link rel="icon" type="image/svg+xml" href={withBase('/favicon.svg')} />
		<link rel="icon" href={withBase('/favicon.ico')} />
		<meta name="viewport" content="width=device-width" />
		<meta name="generator" content={Astro.generator} />
		<title>Thread Placeholder</title>
	</head>
	<body class="min-h-screen bg-slate-100 text-slate-900">
		<main class="flex min-h-screen">
			<LeftSidebar />
			<div class="flex min-h-screen flex-1 flex-col">
				<TopBarHeader title="Messenger" unreadCount={unreadCount} />
				<section class="flex-1 p-6 lg:p-10">
					<div class="mx-auto max-w-4xl space-y-6">
						<a
							href={withBase('/')}
							class="inline-flex items-center rounded-md border border-slate-300 bg-white px-3 py-2 text-sm text-slate-700 hover:bg-slate-50"
						>
							← Back to Threads
						</a>

						<article class="rounded-xl border border-slate-200 bg-white p-6 lg:p-7">
							<div class="flex flex-wrap items-center justify-between gap-3">
								<h1 class="text-2xl font-semibold">{threadTitle}</h1>
								<span class="rounded-md bg-amber-100 px-3 py-1.5 text-xs font-semibold text-amber-800">
									Not Implemented
								</span>
							</div>

							<div class="mt-4 rounded-lg border border-red-200 bg-red-50 px-4 py-3">
								<p class="text-sm font-semibold text-red-800">Placeholder Thread Page</p>
								<p class="mt-1 text-sm text-red-700">
									This thread is not implemented yet. There should be no reason to be on this page right now.
								</p>
							</div>

							<p class="mt-4 rounded-lg bg-slate-50 px-4 py-3 text-sm text-slate-700">
								Use the back button above to return to the thread list or open Homework 1 Autograder Failure for
								the fully mocked thread experience.
							</p>
						</article>

						<section class="rounded-xl border border-slate-200 bg-white p-6 lg:p-7">
							<h2 class="text-lg font-semibold">Status</h2>
							<p class="mt-3 text-sm text-slate-700">
								No post content, responses, or actions are implemented for this placeholder route.
							</p>
						</section>
					</div>
				</section>
			</div>
		</main>
	</body>
</html>
