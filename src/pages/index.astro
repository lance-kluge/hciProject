---
import HomeToolbar from '../components/HomeToolbar.astro';
import LeftSidebar from '../components/sidebar/LeftSidebar.astro';
import TopBarHeader from '../components/TopBarHeader.astro';
import ThreadCard from '../components/ThreadCard.astro';
import { mockThreads } from '../data/home';
import { unreadCount } from '../data/sidebar';
import '../styles/global.css';

---

<html lang="en">
	<head>
		<meta charset="utf-8" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<link rel="icon" href="/favicon.ico" />
		<meta name="viewport" content="width=device-width" />
		<meta name="generator" content={Astro.generator} />
		<title>Canvas Messenger Demo</title>
	</head>
	<body class="min-h-screen bg-slate-100 text-slate-900">
		<main class="flex min-h-screen">
			<LeftSidebar />
			<div class="flex min-h-screen flex-1 flex-col">
				<TopBarHeader title="Messenger" unreadCount={unreadCount} />
				<section id="threads" class="flex-1 p-6 lg:p-7">
					<div class="space-y-3">
						<HomeToolbar />

						<div class="space-y-2.5">
							{mockThreads.map((thread) => (
								<ThreadCard thread={thread} />
							))}
						</div>

						<div class="rounded-lg border border-slate-200 bg-white p-3 text-xs text-slate-700">
							<span class="font-semibold text-green-700">Green</span> is question answered,
							<span class="font-semibold text-orange-700"> Orange</span> is 0-48 hours,
							<span class="font-semibold text-red-700"> Red</span> is anything past 2 days.
						</div>
					</div>
				</section>
			</div>
		</main>
		<script is:inline>
			const threadCards = Array.from(document.querySelectorAll('[data-thread-card]'));
			const threadFilterControls = Array.from(
				document.querySelectorAll('[data-filter-group="thread"][data-filter-value]')
			);

			const activeClass = ['bg-slate-200', 'text-slate-900'];

			const applyFilter = (filterValue) => {
				const normalizedFilter = filterValue || 'all';
				threadCards.forEach((card) => {
					const category = card.getAttribute('data-thread-category');
					const shouldShow = normalizedFilter === 'all' || category === normalizedFilter;
					card.classList.toggle('hidden', !shouldShow);
				});

				threadFilterControls.forEach((control) => {
					const isActive = control.getAttribute('data-filter-value') === normalizedFilter;
					activeClass.forEach((className) => control.classList.toggle(className, isActive));
					if (control.tagName === 'BUTTON') {
						control.setAttribute('aria-pressed', String(isActive));
					}
				});
			};

			threadFilterControls.forEach((control) => {
				control.addEventListener('click', () => {
					const filterValue = control.getAttribute('data-filter-value');
					applyFilter(filterValue);
				});
			});

			applyFilter('all');
		</script>
	</body>
</html>
