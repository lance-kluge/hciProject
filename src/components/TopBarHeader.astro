---
interface Props {
	title: string;
	unreadCount: number;
}

const { title, unreadCount } = Astro.props;
---

<header class="sticky top-0 z-20 flex h-16 items-center justify-between border-b border-slate-200 bg-white px-6">
	<h1 class="text-xl font-semibold text-slate-900">{title}</h1>
	<details class="group relative">
		<summary
			class="list-none rounded-full p-2 text-slate-700 transition hover:cursor-pointer hover:bg-slate-100 hover:text-slate-900"
			aria-label="Open notifications"
		>
			<div class="relative">
				<svg
					xmlns="http://www.w3.org/2000/svg"
					viewBox="0 0 24 24"
					fill="none"
					stroke="currentColor"
					stroke-width="2"
					class="h-6 w-6"
				>
					<path
						stroke-linecap="round"
						stroke-linejoin="round"
						d="M15 17h5l-1.405-1.405A2.032 2.032 0 0 1 18 14.158V11a6.002 6.002 0 0 0-4-5.659V5a2 2 0 1 0-4 0v.341C7.67 6.165 6 8.388 6 11v3.159c0 .538-.214 1.055-.595 1.436L4 17h5"
					/>
					<path stroke-linecap="round" stroke-linejoin="round" d="M9 17a3 3 0 0 0 6 0" />
				</svg>
				<span class="absolute -right-2 -top-2 rounded-full bg-blue-600 px-1.5 py-0.5 text-xs font-semibold leading-none text-white">
					{unreadCount}
				</span>
			</div>
		</summary>

		<div class="absolute right-0 top-12 w-72 rounded-lg border border-slate-200 bg-white p-4 shadow-lg">
			<div class="flex items-center justify-between">
				<p class="text-sm font-semibold text-slate-900">Notification Settings</p>
				<span class="text-xs text-slate-500">{unreadCount} unread</span>
			</div>
			<div class="mt-3 space-y-2 text-sm text-slate-700">
				<label class="flex items-center justify-between gap-3 rounded-md bg-slate-50 px-3 py-2">
					<span>Thread replies</span>
					<input type="checkbox" checked class="h-4 w-4" />
				</label>
				<label class="flex items-center justify-between gap-3 rounded-md bg-slate-50 px-3 py-2">
					<span>Instructor mentions</span>
					<input type="checkbox" checked class="h-4 w-4" />
				</label>
				<label class="flex items-center justify-between gap-3 rounded-md bg-slate-50 px-3 py-2">
					<span>Direct messages</span>
					<input type="checkbox" checked class="h-4 w-4" />
				</label>
			</div>
			<div class="mt-3 flex gap-2">
				<button type="button" class="rounded-md border border-slate-300 px-3 py-1.5 text-xs text-slate-700 hover:bg-slate-50">
					Mute 1 hour
				</button>
				<button type="button" class="rounded-md border border-slate-300 px-3 py-1.5 text-xs text-slate-700 hover:bg-slate-50">
					Mark all read
				</button>
			</div>
		</div>
	</details>
</header>
