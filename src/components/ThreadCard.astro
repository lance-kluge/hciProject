---
import type { ThreadMock, ThreadStatus } from '../data/home';

interface Props {
	thread: ThreadMock;
}

const { thread } = Astro.props;

const statusSquareClass: Record<ThreadStatus, string> = {
	red: 'bg-red-500',
	orange: 'bg-orange-500',
	green: 'bg-green-500'
};

const statusTextClass: Record<ThreadStatus, string> = {
	red: 'text-red-600',
	orange: 'text-orange-600',
	green: 'text-green-600'
};
---

<article
	class="flex items-start gap-3 rounded-lg border border-slate-200 bg-white px-4 py-3"
	data-thread-card
	data-thread-category={thread.category}
>
	<div class="min-w-0 flex-1">
		<div class="flex items-center gap-2">
			<div class={`h-4 w-4 shrink-0 rounded-sm ${statusSquareClass[thread.status]}`}></div>
			<h3 class="truncate text-base font-semibold text-slate-900">{thread.title}</h3>
			<p class={`ml-auto shrink-0 text-xs font-semibold ${statusTextClass[thread.status]}`}>
				{thread.statusLabel}
			</p>
		</div>
		<p class="mt-1.5 text-sm text-slate-600">{thread.aiSummary}</p>
		{thread.footerLabel && <p class="mt-1 text-xs font-semibold text-red-600">{thread.footerLabel}</p>}
	</div>

	{thread.href ? (
		<a
			href={thread.href}
			aria-label={`Open ${thread.title}`}
			class="shrink-0 rounded-md border border-slate-300 bg-white px-3 py-2 text-slate-700 transition hover:bg-slate-50"
		>
			→
		</a>
	) : (
		<button
			type="button"
			aria-label={`Open ${thread.title}`}
			class="shrink-0 rounded-md border border-slate-300 bg-white px-3 py-2 text-slate-700 transition hover:bg-slate-50"
		>
			→
		</button>
	)}
</article>
