---
import ClassSelectorDropdown from './ClassSelectorDropdown.astro';
import SidebarHeadingRow from './SidebarHeadingRow.astro';
import SidebarLinkList from './SidebarLinkList.astro';
import {
  unreadCount,
  selectedClass,
  classOptions,
  threadFilters,
  messagingFilters
} from '../../data/sidebar';

const withBase = (path: string) => `${import.meta.env.BASE_URL}${path.replace(/^\//, '')}`;
---

<aside class="sticky top-0 h-screen w-72 shrink-0 self-start border-r border-slate-200 bg-white">
  <div class="sticky top-0 z-10 border-b border-slate-200 bg-white px-4 py-4">
    <ClassSelectorDropdown selectedClass={selectedClass} classOptions={classOptions} />
  </div>

  <nav aria-label="Inbox sidebar" class="h-[calc(100vh-57px)] space-y-6 overflow-y-auto px-4 py-6">
    <section>
      <SidebarHeadingRow label="Inbox" count={unreadCount} />
    </section>

    <section>
      <SidebarHeadingRow label="Threads" href={withBase('/#threads')} filterGroup="thread" filterValue="all" />
      <SidebarLinkList items={threadFilters} filterGroup="thread" />
    </section>

    <section>
      <SidebarHeadingRow label="Messaging" href={withBase('/messages/messaging/')} filterGroup="message" filterValue="all" />
      <SidebarLinkList items={messagingFilters} filterGroup="message"/>
    </section>
  </nav>
</aside>