---
interface Props {
	label: string;
	count?: number;
}

const { label, count } = Astro.props;
---

<div class="flex items-center justify-between rounded-md px-3 py-2 text-sm font-semibold text-slate-900 hover:bg-slate-100">
	<span>{label}</span>
	{count !== undefined && (
		<span class="rounded-full bg-blue-100 px-2 py-0.5 text-xs font-semibold text-blue-700">
			({count})
		</span>
	)}
</div>
