---
interface Props {
	label: string;
	count?: number;
	href?: string;
	filterGroup?: string;
	filterValue?: string;
}

const { label, count, href, filterGroup, filterValue } = Astro.props;
---

{
	href ? (
		<a
			href={href}
			data-filter-group={filterGroup}
			data-filter-value={filterValue}
			class="flex items-center justify-between rounded-md px-3 py-2 text-sm font-semibold text-slate-900 hover:bg-slate-100"
		>
			<span>{label}</span>
			{count !== undefined && (
				<span class="rounded-full bg-blue-100 px-2 py-0.5 text-xs font-semibold text-blue-700">
					({count})
				</span>
			)}
		</a>
	) : (
		<div
			data-filter-group={filterGroup}
			data-filter-value={filterValue}
			class="flex items-center justify-between rounded-md px-3 py-2 text-sm font-semibold text-slate-900 hover:bg-slate-100"
		>
			<span>{label}</span>
			{count !== undefined && (
				<span class="rounded-full bg-blue-100 px-2 py-0.5 text-xs font-semibold text-blue-700">
					({count})
				</span>
			)}
		</div>
	)
}
